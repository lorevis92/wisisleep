# Freesound API (Nature Sounds)
# Register at: https://freesound.org/apiv2/apply/
VITE_FREESOUND_API_KEY=your_freesound_api_key

# Pixabay API (Sleep Music)
# Register at: https://pixabay.com/api/docs/
VITE_PIXABAY_API_KEY=your_pixabay_api_key

# Podcast Index API (Podcasts)
# Register at: https://api.podcastindex.org/
VITE_PODCASTINDEX_API_KEY=your_podcastindex_api_key
VITE_PODCASTINDEX_API_SECRET=your_podcastindex_api_secret
